# =========================
# Unity generated folders
# =========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get large
[Mm]emoryCaptures/

# =========================
# Asset meta data should only be ignored when the corresponding asset is also ignored
# =========================
!/[Aa]ssets/**/*.meta

# =========================
# Visual Studio / Rider / VSCode
# =========================
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# =========================
# OS generated
# =========================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# =========================
# Unity Cloud Build
# =========================
*.apk
*.aab
*.unitypackage

# =========================
# Crash reports
# =========================
sysinfo.txt

# =========================
# Addressables
# =========================
[Aa]ssets/[Aa]ddressableAssetsData/*/*.bin*

# =========================
# Auto-generated lighting data
# =========================
[Aa]ssets/**/[Ll]ightingData.asset
[Aa]ssets/**/[Ll]ightingData.meta